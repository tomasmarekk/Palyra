{
  "schema_version": 1,
  "release_scope": "compat_plugin_insights_hardening",
  "updated_at": "2026-04-20",
  "profiles": {
    "fast": {
      "description": "Per-push Linux regression subset that still exercises every Phase 8 subsystem at least once.",
      "required_subsystems": [
        "compat_api",
        "secrets",
        "reload",
        "plugin_contracts",
        "context_engine",
        "provider_resilience",
        "auxiliary_routing",
        "retrieval_tuning",
        "safety_boundary",
        "networked_backend",
        "cron_delivery",
        "operator_insights"
      ],
      "minimum_chaos_scenarios": 5
    },
    "full": {
      "description": "Nightly and pre-release workflow regression profile with broader runtime coverage and additional degraded-path validation.",
      "required_subsystems": [
        "compat_api",
        "secrets",
        "reload",
        "plugin_contracts",
        "context_engine",
        "provider_resilience",
        "auxiliary_routing",
        "retrieval_tuning",
        "safety_boundary",
        "networked_backend",
        "cron_delivery",
        "operator_insights"
      ],
      "minimum_chaos_scenarios": 8
    }
  },
  "required_subsystems": [
    {
      "id": "compat_api",
      "summary": "OpenAI-compatible models, embeddings, and guarded tools invoke surface."
    },
    {
      "id": "secrets",
      "summary": "SecretRef resolution, redaction, and missing-secret recovery behavior."
    },
    {
      "id": "reload",
      "summary": "Config migrate, reload planning, and recovery behavior after operator changes."
    },
    {
      "id": "plugin_contracts",
      "summary": "Typed plugin contract negotiation, discovery, and invalid config handling."
    },
    {
      "id": "context_engine",
      "summary": "Context assembly, session compaction, and legacy/context-engine interop."
    },
    {
      "id": "provider_resilience",
      "summary": "Provider failover, degraded auth posture, and compat embeddings fallback handling."
    },
    {
      "id": "auxiliary_routing",
      "summary": "Auxiliary routing and lease-pressure degradation decisions."
    },
    {
      "id": "retrieval_tuning",
      "summary": "Retrieval backend/scoring config and degraded retrieval diagnostics."
    },
    {
      "id": "safety_boundary",
      "summary": "Safety gates around guarded compat/tool and networked worker execution."
    },
    {
      "id": "networked_backend",
      "summary": "Networked worker inventory, attestation, lifecycle, and restricted tool posture."
    },
    {
      "id": "cron_delivery",
      "summary": "Cron workflow delivery, list/runs surfaces, and ownership boundaries."
    },
    {
      "id": "operator_insights",
      "summary": "Operator insights API and diagnostics exposure for degraded hotspots."
    }
  ],
  "setup_steps": [
    {
      "id": "build-core",
      "label": "Build palyra-daemon and palyra-cli for workflow regression",
      "profiles": [
        "fast",
        "full"
      ],
      "command": [
        "cargo",
        "build",
        "-p",
        "palyra-daemon",
        "-p",
        "palyra-cli",
        "--locked"
      ]
    },
    {
      "id": "build-browserd",
      "label": "Build palyra-browserd for browser and channel workflow coverage",
      "profiles": [
        "full"
      ],
      "command": [
        "cargo",
        "build",
        "-p",
        "palyra-browserd",
        "--bin",
        "palyra-browserd",
        "--locked"
      ]
    }
  ],
