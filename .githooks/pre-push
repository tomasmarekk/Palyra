#!/usr/bin/env bash
set -euo pipefail

echo "Running rustfmt check..."
cargo fmt --all --check

echo "Checking runtime artifact hygiene before local validation..."
bash scripts/check-runtime-artifacts.sh

echo "Checking desktop glib patch governance..."
bash scripts/check-desktop-glib-patch.sh

echo "Running clippy..."
cargo clippy --workspace --all-targets -- -D warnings

echo "Running unit and integration tests..."
cargo test --workspace --locked

echo "Running protocol schema checks..."
bash scripts/protocol/validate-proto.sh
bash scripts/protocol/generate-stubs.sh
bash scripts/protocol/validate-rust-stubs.sh

echo "Running high-risk pattern scan..."
bash scripts/check-high-risk-patterns.sh

echo "Cleaning runtime artifacts generated during local validation..."
bash scripts/clean-runtime-artifacts.sh

echo "Running runtime artifact hygiene guard..."
bash scripts/check-runtime-artifacts.sh
