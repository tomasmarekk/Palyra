{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.palyra.dev/json/envelopes/a2ui-envelope.v1.json",
  "title": "A2UI Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "v",
    "id",
    "surface",
    "patch"
  ],
  "properties": {
    "v": {
      "const": 1
    },
    "id": {
      "$ref": "../common/canonical-id.v1.json"
    },
    "surface": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "patch": {
      "type": "object",
      "maxProperties": 256
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_payload_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 262144
        }
      }
    }
  }
}
