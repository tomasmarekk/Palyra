{
  "name": "@palyra/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10 <12"
  },
  "scripts": {
    "bootstrap": "node ./scripts/devex.mjs bootstrap",
    "build": "vite build",
    "ci:check": "node ./scripts/devex.mjs ci-check",
    "clean": "node ./scripts/devex.mjs clean",
    "cleanroom:check": "node ./scripts/devex.mjs cleanroom-check",
    "dev": "vite",
    "lint": "eslint \"**/*.{ts,tsx}\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify-install": "node ./scripts/devex.mjs verify-install"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.2",
    "fast-check": "^4.5.3",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
