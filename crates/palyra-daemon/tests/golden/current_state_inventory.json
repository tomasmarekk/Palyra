  "migration_notes": [
    {
      "id": "m52-page-meta",
      "message": "M52 adds typed contract/page/error metadata while preserving legacy response keys for existing dashboard consumers."
    },
    {
      "id": "m52-openai-contract",
      "message": "OpenAI provider auth endpoints publish the control-plane contract in M52; interactive OAuth bootstrap/callback UX is completed in M54."
    },
    {
      "id": "m56-capability-exposure",
      "message": "M56 expands capability catalog entries with dashboard section ownership and CLI handoff metadata so the dashboard can surface direct actions, read-only handoffs, and internal-only capabilities explicitly."
    }
  ],
  "feature_rollouts": {
    "dynamic_tool_builder": {
      "enabled": false,
      "source": "default",
      "config_path": "feature_rollouts.dynamic_tool_builder",
      "env_var": "PALYRA_EXPERIMENTAL_DYNAMIC_TOOL_BUILDER"
    },
    "context_engine": {
      "enabled": false,
      "source": "default",
      "config_path": "feature_rollouts.context_engine",
      "env_var": "PALYRA_EXPERIMENTAL_CONTEXT_ENGINE"
    },
    "execution_backend_remote_node": {
      "enabled": false,
      "source": "default",
      "config_path": "feature_rollouts.execution_backend_remote_node",
      "env_var": "PALYRA_EXPERIMENTAL_EXECUTION_BACKEND_REMOTE_NODE"
    },
    "execution_backend_ssh_tunnel": {
      "enabled": false,
      "source": "default",
      "config_path": "feature_rollouts.execution_backend_ssh_tunnel",
      "env_var": "PALYRA_EXPERIMENTAL_EXECUTION_BACKEND_SSH_TUNNEL"
    }
  },
  "execution_backend_preferences": [
    "automatic",
    "local_sandbox",
    "desktop_node",
    "ssh_tunnel"
  ],
  "execution_backends": [
    {
      "backend_id": "desktop_node",
      "label": "Desktop node",
      "state": "disabled",
      "selectable": false,
      "selected_by_default": false,
      "description": "Hand work off to a paired first-party desktop node when a healthy node is available.",
      "rollout_flag": "PALYRA_EXPERIMENTAL_EXECUTION_BACKEND_REMOTE_NODE",
      "rollout_enabled": false,
      "capabilities": [
        "paired_desktop_capabilities"
      ],
      "tradeoffs": [
        "Supports first-party desktop capabilities and local mediation flows",
        "Depends on node heartbeat, pairing trust, and explicit rollout opt-in"
      ],
      "active_node_count": 0,
      "total_node_count": 0
    },
    {
      "backend_id": "local_sandbox",
      "label": "Local sandbox",
      "state": "available",
      "selectable": true,
      "selected_by_default": true,
      "description": "Run work on the daemon host and keep sandbox/process-runner guardrails local.",
      "rollout_flag": null,
      "rollout_enabled": true,
      "capabilities": [
        "daemon_host_execution",
        "workspace_patch"
      ],
      "tradeoffs": [
        "Most conservative default posture",
        "Cannot satisfy first-party desktop-native capability requests by itself"
      ],
      "active_node_count": 0,
      "total_node_count": 0
    },
    {
      "backend_id": "ssh_tunnel",
      "label": "SSH tunnel",
      "state": "disabled",
      "selectable": false,
      "selected_by_default": false,
      "description": "Use an operator-established SSH tunnel for remote control-plane access and remote operator workflows.",
      "rollout_flag": "PALYRA_EXPERIMENTAL_EXECUTION_BACKEND_SSH_TUNNEL",
      "rollout_enabled": false,
      "capabilities": [
        "verified_remote_dashboard_access",
        "operator_handoff"
      ],
      "tradeoffs": [
        "Useful for explicit remote operator access and controlled handoff",
        "Requires manual tunnel setup and does not replace sandbox or node trust boundaries"
      ],
      "active_node_count": 0,
      "total_node_count": 0
    }
  ],
